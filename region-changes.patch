+        const [evtLow, evtHigh] = nums
+        return evtLow <= bucket.high && evtHigh >= bucket.low
       }
+
+      // 2) Keyword fallback
+      return bucket.keywords.some((kw) => content.includes(kw))
     })
   }
 
