  * Used by local-scraper-runner.js to execute scrapers locally
  *
  * Created: January 2026 - Cloud-to-Local Migration
+ * Updated: April 2026 - Regional expansion support (DMV → Eastern → Central → Western)
  */
 
+const fs = require('fs');
+const path = require('path');
+
+// ============================================================================
+// REGION CONFIGURATION
+// ============================================================================
+
+const REGION_CONFIG_PATH = path.join(__dirname, 'region-config.json');
+
+function loadRegionConfig() {
+  try {
+    return JSON.parse(fs.readFileSync(REGION_CONFIG_PATH, 'utf-8'));
+  } catch (err) {
+    console.warn('[WARN] Could not load region-config.json, defaulting to all states active');
+    return null;
+  }
+}
+
+/**
+ * Get the list of currently active states based on region-config.json
+ * @returns {string[]} Array of active state codes (e.g., ['DC', 'MD', 'VA'])
+ */
+function getActiveStates() {
+  const config = loadRegionConfig();
+  if (!config) return null; // null means "run everything" (backwards compatible)
+
+  const activeStates = [];
+  for (const regionKey of config.activeRegions || []) {
+    const region = config.regions[regionKey];
+    if (region && region.active) {
+      activeStates.push(...region.states);
+    }
+  }
+  return activeStates;
+}
+
+/**
+ * Get the region name for a given state code
+ * @param {string} stateCode - Two-letter state code
+ * @returns {string|null} Region key (dmv, eastern, central, western) or null
+ */
+function getRegionForState(stateCode) {
+  const config = loadRegionConfig();
+  if (!config) return null;
+
+  for (const [regionKey, region] of Object.entries(config.regions)) {
+    if (region.states.includes(stateCode)) {
+      return regionKey;
+    }
+  }
+  return null;
+}
+
+/**
+ * Check if a scraper should run based on active regions
+ * @param {Object} scraperConfig - Scraper config object with state field
+ * @param {string[]|null} activeStates - Active states (null = run all)
+ * @returns {boolean}
+ */
+function isScraperActive(scraperConfig, activeStates) {
+  if (!activeStates) return true; // No region filtering
+  if (!scraperConfig.state) return true; // No state info = run it
+  if (scraperConfig.state === 'Multi') return true; // Multi-state scrapers always run (they filter internally)
+  return activeStates.includes(scraperConfig.state);
+}
+
 // Day groups for 3-day rotation schedule
 // Group 1: Days 1, 4, 7, 10, 13, 16, 19, 22, 25, 28, 31
 // Group 2: Days 2, 5, 8, 11, 14, 17, 20, 23, 26, 29
@@ -1343,6 +1410,102 @@ function getMacaroniSiteCounts() {
   return counts;
 }
 
+// ============================================================================
+// REGION-AWARE GETTERS
+// ============================================================================
+
+/**
+ * Get scrapers for a group, filtered by active regions
+ * @param {number} group - Group number (1, 2, or 3)
+ * @param {Object} options - { regionFilter: string[]|null } override active states
+ * @returns {Object} Filtered scrapers
+ */
+function getScrapersForGroupByRegion(group, options = {}) {
+  const activeStates = options.regionFilter || getActiveStates();
+  const result = {};
+  for (const [name, config] of Object.entries(SCRAPERS)) {
+    if (config.group === group && isScraperActive(config, activeStates)) {
+      result[name] = config;
+    }
+  }
+  return result;
+}
+
+/**
+ * Get Macaroni Kid scrapers for a group, filtered by active regions
+ * @param {number} group - Group number (1, 2, or 3)
+ * @param {Object} options - { regionFilter: string[]|null } override active states
+ * @returns {Object} Filtered Macaroni Kid scrapers
+ */
+function getMacaroniScrapersForGroupByRegion(group, options = {}) {
+  const activeStates = options.regionFilter || getActiveStates();
+  const result = {};
+  for (const [name, config] of Object.entries(MACARONI_SCRAPERS)) {
+    if (config.group === group && isScraperActive(config, activeStates)) {
+      result[name] = config;
+    }
+  }
+  return result;
+}
+
+/**
+ * Get OSM scrapers for a day, filtered by active regions
+ * @param {number} dayOfMonth - Day of the month (1-10)
+ * @param {Object} options - { regionFilter: string[]|null } override active states
+ * @returns {Object} Filtered OSM scrapers
+ */
+function getOSMScrapersForDayByRegion(dayOfMonth, options = {}) {
+  const activeStates = options.regionFilter || getActiveStates();
+  if (!activeStates) return getOSMScrapersForDay(dayOfMonth);
+
+  const result = {};
+  for (const [name, config] of Object.entries(OSM_SCRAPERS)) {
+    if (config.day === dayOfMonth) {
+      // OSM batches have a states array - check if any overlap with active states
+      const batchStates = config.states || [];
+      const activeInBatch = batchStates.filter(s => activeStates.includes(s));
+      if (activeInBatch.length > 0) {
+        result[name] = { ...config, activeStates: activeInBatch };
+      }
+    }
+  }
+  return result;
+}
+
+/**
+ * Get a summary of scrapers by region for display
+ * @returns {Object} { dmv: { scrapers: N, macaroni: N }, eastern: { ... }, ... }
+ */
+function getRegionSummary() {
+  const config = loadRegionConfig();
+  if (!config) return null;
+
+  const summary = {};
+  for (const [regionKey, region] of Object.entries(config.regions)) {
+    const states = region.states;
+    let scraperCount = 0;
+    let macaroniCount = 0;
+
+    for (const cfg of Object.values(SCRAPERS)) {
+      if (states.includes(cfg.state)) scraperCount++;
+    }
+    for (const cfg of Object.values(MACARONI_SCRAPERS)) {
+      if (states.includes(cfg.state)) macaroniCount++;
+    }
+
+    summary[regionKey] = {
+      name: region.name,
+      active: region.active,
+      phase: region.phase,
+      states: states.length,
+      scrapers: scraperCount,
+      macaroni: macaroniCount,
+      total: scraperCount + macaroniCount
+    };
+  }
+  return summary;
+}
+
 module.exports = {
   SCRAPERS,
   MACARONI_SCRAPERS,
